# GitHub OAuth App for the DCJ "Real Target" demo.
# Create one at: https://github.com/settings/applications/new
#
# Local dev (match your Slidev port):
#   Homepage URL:           http://127.0.0.1:3030
#   Authorization callback: http://127.0.0.1:3030/callback/
#
# Production (https://presentations.melmayan.fr/clickjacking):
#   Homepage URL:           https://presentations.melmayan.fr/clickjacking
#   Authorization callback: https://presentations.melmayan.fr/clickjacking/callback/
#
# The fallback client_id (GitHub CLI) only works on localhost — set your own for production.

VITE_GITHUB_OAUTH_CLIENT_ID=
VITE_GITHUB_OAUTH_SCOPE=read:user
# Optional override; leave empty to use window.location.origin + /callback/
VITE_GITHUB_OAUTH_REDIRECT_URI=
